<Window x:Class="FifaFootballGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FifaFootballGame"
        mc:Ignorable="d"
        Title="FIFA Football 2000" Height="420" Width="640" 
        WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#0a3a2a" Offset="0"/>
            <GradientStop Color="#0a1a0a" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#1A1A2E" Offset="0"/>
                        <GradientStop Color="#16213E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,30,0"/>
        </Style>

        <!-- Стиль для кнопки EXIT -->
        <Style TargetType="Button" x:Key="ExitButton">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#3a1c1c" Offset="0"/>
                        <GradientStop Color="#1a0a0a" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#8B0000"/>
        </Style>
    </Window.Resources>

    <!-- Главный контейнер с кнопками -->
    <Grid>
        <!-- Логотип FIFA -->
        <TextBlock Text="FIFA" FontSize="48" FontWeight="Bold" 
                   FontFamily="Arial Black" 
                   Foreground="#FFD700" 
                   HorizontalAlignment="Left" VerticalAlignment="Top" 
                   Margin="20,20,0,0"/>

        <TextBlock Text="2027" FontSize="36" FontWeight="Bold" 
                   FontFamily="Arial Black" 
                   Foreground="White" 
                   HorizontalAlignment="Left" VerticalAlignment="Top" 
                   Margin="130,38,0,0" Opacity="0.8"/>

        <!-- Панель с кнопками справа -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0">
            <Button Content="ИГРАТЬ" Margin="0,0,0,15" Click="Button_Click" Command="{Binding ButtonPlay}"/>
            <Button Content="СЕТЕВАЯ ИГРА" Margin="0,0,0,15" Command="{Binding ButtonRegister}" Click="Button_Click_1"/>
            <Button Content="НАСТРОЙКИ" Margin="0,0,0,15" Command="{Binding ButtonSettings}"/>
            <Button Content="ВЫЙТИ" Style="{StaticResource ExitButton}" Click="Button_Exit" Height="31" Foreground="GreenYellow"/>
        </StackPanel>

        <!-- Декоративная линия -->
        <Rectangle Height="2" Fill="#FFD700" Opacity="0.5" 
                   VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="20,0,20,20"/>

        <TextBlock Text="© 2027 FUTBOLER_PLAYS" FontSize="10" 
                   Foreground="White" Opacity="0.5"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10"/>
    </Grid>
</Window>