<Window x:Class="FifaFootballGame.MultiGamePlayer.MultigameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FifaFootballGame.MultiGamePlayer"
        mc:Ignorable="d"
        Title="Серверная игра" Height="420" Width="640" 
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#0a1a0a" Offset="0"/>
            <GradientStop Color="#0a2a1a" Offset="0.5"/>
            <GradientStop Color="#0a1a0a" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#1a1a2e" Offset="0"/>
                        <GradientStop Color="#16213e" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="CaretBrush" Value="#FFD700"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#1A1A2E" Offset="0"/>
                        <GradientStop Color="#16213E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,280,0,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- Светящийся эффект для кнопок при наведении -->
        <Style TargetType="Button" x:Key="GlowButton" BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FFD700" 
                                              ShadowDepth="0" 
                                              BlurRadius="15" 
                                              Opacity="0.8"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#2a2a4e" Offset="0"/>
                                <GradientStop Color="#26314e" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Фоновый декоративный элемент - круг как на футбольном поле -->
        <Ellipse Width="200" Height="200" 
                 Stroke="#FFD700" StrokeThickness="1" Opacity="0.1"
                 HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Декоративный элемент в центре поля -->
        <Ellipse Width="16" Height="16" Fill="#FFD700" Opacity="0.3"
                 HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Логотип в шапке -->
        <TextBlock Text="MULTIPLAYER" 
                   FontSize="18" FontWeight="Bold" FontFamily="Arial Black"
                   Foreground="#FFD700" Opacity="0.6"
                   HorizontalAlignment="Center" VerticalAlignment="Top" 
                   Margin="0,15,0,0"/>

        <TextBlock Text="⚽" 
                   FontSize="24" 
                   Foreground="#FFD700" Opacity="0.4"
                   HorizontalAlignment="Left" VerticalAlignment="Top" 
                   Margin="15,10,0,0"/>

        <TextBlock Text="⚽" 
                   FontSize="24" 
                   Foreground="#FFD700" Opacity="0.4"
                   HorizontalAlignment="Right" VerticalAlignment="Top" 
                   Margin="0,10,15,0"/>

        <!-- Заголовок IP -->
        <TextBlock Text="IP АДРЕС" 
                   FontSize="10" FontWeight="Bold" FontFamily="Arial Black"
                   Foreground="#FFD700" Opacity="0.7"
                   Margin="220,95,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <TextBox x:Name="IpTextBox"
                 Text="127.0.0.1"
                 Width="200"
                 Height="30"
                 Margin="220,110,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 PreviewTextInput="IpTextBox_PreviewTextInput"/>

        <!-- Заголовок PORT -->
        <TextBlock Text="PORT" 
                   FontSize="10" FontWeight="Bold" FontFamily="Arial Black"
                   Foreground="#FFD700" Opacity="0.7"
                   Margin="220,155,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <TextBox x:Name="PortTextBox"
                 Text="5000"
                 Width="200"
                 Height="30"
                 Margin="220,170,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 PreviewTextInput="PortTextBox_PreviewTextInput"/>

        <Button x:Name="CreateServerButton"
                Content="СОЗДАТЬ СЕРВЕР"
                Width="160"
                Height="40"
                Margin="60,280,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Click="CreateServerButton_Click"
                Style="{StaticResource GlowButton}"/>

        <Button x:Name="ConnectButton"
                Content="ПОДКЛЮЧИТЬСЯ"
                Width="160"
                Height="40"
                Margin="400,280,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Click="ConnectButton_Click"
                Style="{StaticResource GlowButton}"/>

        <!-- Декоративная линия снизу -->
        <Rectangle Height="2" Fill="#FFD700" Opacity="0.3" 
                   VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="40,0,40,15"/>

        <TextBlock Text="Онлайн-игра" FontSize="8" 
                   Foreground="#FFD700" Opacity="0.3"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8"
                   FontFamily="Arial Black"/>
    </Grid>
</Window>